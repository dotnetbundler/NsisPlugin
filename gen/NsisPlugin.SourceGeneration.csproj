<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <AnalyzerLanguage>cs</AnalyzerLanguage>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.0.0" PrivateAssets="all"/>
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\Common\NsisPlugin\**\*.cs" Link="Common\NsisPlugin\%(RecursiveDir)%(Filename)%(Extension)"/>
    <Compile Include="..\Common\System.Diagnostics.CodeAnalysis\NullableAttributes.cs" Link="Common\System.Diagnostics.CodeAnalysis\NullableAttributes.cs"/>
    <Compile Include="..\Common\System.Runtime.CompilerServices\IsExternalInit.cs" Link="Common\System.Runtime.CompilerServices\IsExternalInit.cs"/>
    <Compile Include="..\Common\System.Runtime.InteropServices\NativeMemory.cs" Link="Common\System.Runtime.InteropServices\NativeMemory.cs"/>
  </ItemGroup>

</Project>
