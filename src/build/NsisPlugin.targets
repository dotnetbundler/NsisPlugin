<Project>
  <PropertyGroup>
    <DefineConstants Condition="'$(NsisPluginUseUnicode)' == 'true'">$(DefineConstants);NSIS_UNICODE</DefineConstants>
  </PropertyGroup>

  <!-- 将属性暴露给 Source Generator -->
  <ItemGroup>
    <CompilerVisibleProperty Include="NsisPluginGenerateInitializer"/>
    <CompilerVisibleProperty Include="NsisPluginUseSharedEntryInit"/>
  </ItemGroup>
</Project>
