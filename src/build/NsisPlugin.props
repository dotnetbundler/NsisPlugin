<Project>
  <PropertyGroup>
    <!-- 是否让插件默认使用 Unicode 编码 -->
    <NsisPluginUseUnicode>false</NsisPluginUseUnicode>
    <!-- 是否自动生成 Nsis 插件初始化器 -->
    <NsisPluginGenerateInitializer>true</NsisPluginGenerateInitializer>
    <!-- 是否使用共享入口初始化模式生成导出 -->
    <NsisPluginUseSharedEntryInit>false</NsisPluginUseSharedEntryInit>
  </PropertyGroup>
</Project>
